# Path to CIV–MEM repo root (content, docs, .cursor). Default: parent of apps/chat.
CIVMEM_CONTENT_ROOT=

# OpenAI API key (for chat engine).
OPENAI_API_KEY=

# Telegram Bot Token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Optional: port for HTTP server (webhook + health). Default 3000.
PORT=3000

# Optional: base URL for webhook (e.g. https://your-domain.com). Required for Telegram webhook.
# WEBHOOK_BASE_URL=
