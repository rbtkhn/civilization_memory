{
  "name": "civmem-chat",
  "version": "0.1.0",
  "private": true,
  "description": "Chat backend and adapters (Telegram, WeChat) for CIV–MEM",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "telegram": "node src/index.js",
    "eval": "node scripts/eval-engine.js",
    "eval:rotate": "EVAL_ROTATE=1 node scripts/eval-engine.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.64.0",
    "openai": "^4.52.0"
  }
}
